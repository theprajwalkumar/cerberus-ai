{
  "manifest_version": 3,
  "name": "HostedScan LLM Bridge",
  "version": "1.0.0",
  "description": "Captures ChatGPT conversations and sends them to your HostedScan platform for logging, policy enforcement, and red-teaming.",
  "permissions": ["storage", "scripting"],
  "host_permissions": ["https://chatgpt.com/*", "https://chat.openai.com/*", "https://*.chatgpt.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*", "https://*.chatgpt.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
